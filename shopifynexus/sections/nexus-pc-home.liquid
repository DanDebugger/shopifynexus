{{ 'section-nexus-pc-home.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign collection_products_url = routes.all_products_collection_url | append: '#product-grid'
  assign top_products = shop.metafields.nexus.top_products.value
  if top_products != blank
    assign bestseller_product = top_products.first
  else
    assign bestseller_product = all_products['nexuslab-prime-2']
  endif
-%}

<section class="nexus-home-minimal">
  <div class="nexus-home-minimal__hero">
    <div class="nexus-home-minimal__wrap">
      <div class="nexus-home-minimal__hero-grid">
        <div>
          <h1>Gear up for your next build</h1>
          <p class="nexus-home-minimal__subtext">
            Shop NexusLab PC bundles built for gaming, school, streaming, editing, and everyday work.
          </p>
          <div class="nexus-home-minimal__actions">
            <a class="nexus-home-minimal__button" href="{{ routes.all_products_collection_url }}">Shop bundles</a>
            <a class="nexus-home-minimal__button nexus-home-minimal__button--secondary" href="{{ collection_products_url }}">Build custom</a>
          </div>
        </div>
        <div class="nexus-home-minimal__hero-image-wrap">
          <img class="nexus-home-minimal__hero-img" src="{{ 'nexus-home-hero.jpg' | asset_url }}" alt="Developer using custom PC workstation setup" width="1200" height="890">
        </div>
      </div>
    </div>
  </div>

  <div class="nexus-home-minimal__section">
    <div class="nexus-home-minimal__wrap">
      <div class="nexus-home-minimal__heading-row">
        <div>
          <p class="nexus-home-minimal__eyebrow">PC selling and bundles</p>
          <h2>Featured bundles</h2>
        </div>
        <a class="nexus-home-minimal__view-all" href="{{ routes.all_products_collection_url }}">View all bundles →</a>
      </div>

      <div class="nexus-home-minimal__carousel" data-nexus-carousel>
        <div class="nexus-home-minimal__carousel-controls" aria-label="Featured bundle carousel controls">
          <button class="nexus-home-minimal__carousel-button" type="button" data-carousel-prev aria-label="Previous featured bundles">‹</button>
          <button class="nexus-home-minimal__carousel-button" type="button" data-carousel-next aria-label="Next featured bundles">›</button>
        </div>
        <div class="nexus-home-minimal__carousel-viewport" data-carousel-viewport>
          <div class="nexus-home-minimal__grid">
          {%- if top_products != blank -%}
            {%- for product in top_products -%}
              <a class="nexus-home-minimal__card" href="{{ product.url }}">
                <span class="nexus-home-minimal__badge">#{{ forloop.index }} Ranked</span>
                {%- if product.featured_image -%}
                  <img class="nexus-home-minimal__card-media" src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title | escape }}" width="900" height="680">
                {%- else -%}
                  <div style="background: #e2e2e2; height: 300px; border-radius: 8px; margin-bottom: 12px;"></div>
                {%- endif -%}
                <span class="nexus-home-minimal__tier">Tier {{ product.metafields.nexus.rank_tier.value | default: 'A' }}</span>
                <h3>{{ product.title }}</h3>
                <p class="nexus-home-minimal__details">{{ product.description | strip_html | truncate: 80 }}</p>
                <span class="nexus-home-minimal__price">{{ product.price | money }}</span>
              </a>
            {%- endfor -%}
          {%- else -%}
            <p style="padding: 24px;">No rankings available yet. Once an order is placed, the leaderboard will update!</p>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

</div>


  <div class="nexus-home-minimal__section">
    <div class="nexus-home-minimal__wrap">
      <div class="nexus-home-minimal__experience">
        <div class="nexus-home-minimal__experience-main">
          <p class="nexus-home-minimal__eyebrow">Custom product experience</p>
          <h2>Tell us how you work. We shape the setup.</h2>
          <p>
            Start from a real bundle, then tune the monitor, storage, memory, cooling, and accessories around your budget and daily workload.
          </p>
          <ul class="nexus-home-minimal__experience-steps">
            <li><span>01</span> Pick gaming, study, creator, office, or workstation</li>
            <li><span>02</span> Match the build to your budget and desk size</li>
            <li><span>03</span> Checkout with parts guidance and setup support</li>
          </ul>
        </div>
        <div class="nexus-home-minimal__recommendation">
          <div>
            <p class="nexus-home-minimal__eyebrow">Smart recommendation</p>
            <h3>Fast paths for common buyers</h3>
            <p>Use these shortcuts when you know the goal but not the exact specs yet.</p>
          </div>
          <div class="nexus-home-minimal__recommendation-options">
            <a class="nexus-home-minimal__recommendation-option" href="{{ collection_products_url }}"><span>Student</span> NexusBook Air</a>
            <a class="nexus-home-minimal__recommendation-option" href="{{ collection_products_url }}"><span>Esports</span> NexusLab Esports</a>
            <a class="nexus-home-minimal__recommendation-option" href="{{ collection_products_url }}"><span>Creator</span> NexusLab Prime 2</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="nexus-home-minimal__section">
    <div class="nexus-home-minimal__wrap">
      <div class="nexus-home-minimal__bestseller">
        <div class="nexus-home-minimal__bestseller-product">
          <p class="nexus-home-minimal__eyebrow">Bestseller</p>
          <div class="nexus-home-minimal__bestseller-image-wrap">
            {%- if bestseller_product.featured_image -%}
              <img class="nexus-home-minimal__bestseller-image" src="{{ bestseller_product.featured_image | image_url: width: 900 }}" alt="{{ bestseller_product.title | escape }}" width="900" height="680">
            {%- else -%}
              <div style="background: #e2e2e2; height: 300px; border-radius: 8px; margin-bottom: 12px;"></div>
            {%- endif -%}
          <h2>{{ bestseller_product.title | default: 'NexusLab Prime 2' }}</h2>
          <span class="nexus-home-minimal__bestseller-price">{{ bestseller_product.price | money }}</span>
          <a class="nexus-home-minimal__button" href="{{ bestseller_product.url | default: collection_products_url }}">Shop now</a>
        </div>

        <div class="nexus-home-minimal__bestseller-copy">
          <div>
            <p class="nexus-home-minimal__eyebrow">Why it's bestseller</p>
            <h2>{{ bestseller_product.title | default: 'Engineered for ultimate 1440p gaming' }}</h2>
          </div>
          <p>
            {{ bestseller_product.description | strip_html | truncate: 150 | default: 'Configured for smooth high-refresh gaming, streaming, and creative work with clean thermals and upgrade-ready parts.' }}
          </p>
          <dl class="nexus-home-minimal__bestseller-features">
            <div>
              <dt>CPU</dt>
              <dd>{{ bestseller_product.metafields.nexus.cpu.value | default: 'Intel Core i7-13700K' }}</dd>
            </div>
            <div>
              <dt>GPU</dt>
              <dd>{{ bestseller_product.metafields.nexus.gpu.value | default: 'NVIDIA GeForce RTX 4070 Ti' }}</dd>
            </div>
            <div>
              <dt>RAM</dt>
              <dd>{{ bestseller_product.metafields.nexus.ram.value | default: '32GB DDR5' }}</dd>
            </div>
            <div>
              <dt>Storage</dt>
              <dd>{{ bestseller_product.metafields.nexus.storage.value | default: '1TB NVMe SSD' }}</dd>
            </div>
          </dl>
          <figure class="nexus-home-minimal__review">
            <div class="nexus-home-minimal__stars" aria-label="Five star rating">★★★★★</div>
            <blockquote>
              "The thermal performance on Prime 2 is absolutely insane. Highly recommend the complete desk setup bundle."
            </blockquote>
            <figcaption>John D. / Verified buyer</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </div>
  </div>

  <div class="nexus-home-minimal__section">
    <div class="nexus-home-minimal__wrap">
      <div class="nexus-home-minimal__heading-row">
        <div>
          <p class="nexus-home-minimal__eyebrow">Shop by setup</p>
          <h2>Build around your need</h2>
        </div>
      </div>

      <div class="nexus-home-minimal__category-grid">
        <a class="nexus-home-minimal__category" href="{{ collection_products_url }}">
          <img src="{{ 'nexus-laptop-air.jpg' | asset_url }}" alt="Student and productive laptop setup" width="720" height="540">
          <h3>Productive Laptops</h3>
          <p>Slim, portable notebooks bundled with external monitor options for study and hybrid work.</p>
        </a>
        <a class="nexus-home-minimal__category" href="{{ collection_products_url }}">
          <img src="{{ 'nexus-mini.jpg' | asset_url }}" alt="Compact Mini PC setup" width="720" height="540">
          <h3>Mini Computers</h3>
          <p>Compact, space-saving desktop PCs perfect for home study, office, and light gaming.</p>
        </a>
        <a class="nexus-home-minimal__category" href="{{ collection_products_url }}">
          <img src="{{ 'nexus-esports.jpg' | asset_url }}" alt="Esports gaming PC setup" width="720" height="540">
          <h3>Esports Systems</h3>
          <p>High frame-rate gaming towers optimized for competitive gaming and multiplayer esports.</p>
        </a>
        <a class="nexus-home-minimal__category" href="{{ collection_products_url }}">
          {%- if bestseller_product.featured_image -%}
            <img src="{{ bestseller_product.featured_image | image_url: width: 720 }}" alt="{{ bestseller_product.featured_image.alt | default: 'Performance PC desk setup' | escape }}" width="720" height="540">
          {%- else -%}
            <img src="{{ 'nexus-prime-2.jpg' | asset_url }}" alt="Performance PC desk setup" width="720" height="540">
          {%- endif -%}
          <h3>Performance bundles</h3>
          <p>Balanced PC setups for 1440p high-refresh gaming, live streaming, and content creation.</p>
        </a>
        <a class="nexus-home-minimal__category" href="{{ collection_products_url }}">
          <img src="{{ 'nexus-prime-3.jpg' | asset_url }}" alt="Pro workstation setup" width="720" height="540">
          <h3>Pro workstation</h3>
          <p>Extreme performance setups for coding, rendering, 3D animations, and local AI workloads.</p>
        </a>
      </div>
    </div>
  </div>

  <div class="nexus-home-minimal__section" style="padding-top: 0;">
    <div class="nexus-home-minimal__wrap">
      {%- for block in section.blocks -%}
        {% render block %}
      {%- endfor -%}
    </div>
  </div>

</section>

<script>
  (() => {
    const carousel = document.querySelector("[data-nexus-carousel]");
    if (!carousel) return;

    const viewport = carousel.querySelector("[data-carousel-viewport]");
    const previous = carousel.querySelector("[data-carousel-prev]");
    const next = carousel.querySelector("[data-carousel-next]");
    const scrollAmount = () => Math.max(280, viewport.clientWidth * 0.82);

    previous?.addEventListener("click", () => {
      viewport.scrollBy({ left: -scrollAmount(), behavior: "smooth" });
    });

    next?.addEventListener("click", () => {
      viewport.scrollBy({ left: scrollAmount(), behavior: "smooth" });
    });
  })();
</script>

